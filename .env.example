# Copie a .env y ajuste (no suba .env al repositorio)

DB_HOST=localhost
DB_PORT=5432
DB_NAME=clinical_request_db
DB_USER=medihelp
DB_PASSWORD=cambiar

PORT=3000

# Sesion panel medico (cambie en produccion)
SESSION_SECRET=cambiar_por_cadena_larga_aleatoria

# Primer usuario en users_consent si la tabla esta vacia al arrancar
USERS_CONSENT_BOOTSTRAP_USERNAME=admin
USERS_CONSENT_BOOTSTRAP_PASSWORD=cambiar
# Datos del medico (bootstrap)
# USERS_CONSENT_BOOTSTRAP_TIPO_DOC=CC
# USERS_CONSENT_BOOTSTRAP_NUMERO_DOC=1234567890
# USERS_CONSENT_BOOTSTRAP_NOMBRES=Juan
# USERS_CONSENT_BOOTSTRAP_APELLIDOS=Perez
# USERS_CONSENT_BOOTSTRAP_REGISTRO_MEDICO=123456
# USERS_CONSENT_BOOTSTRAP_NOMBRE=Administrador
# USERS_CONSENT_BOOTSTRAP_ESPECIALIDAD=Anestesiologia
# Para panel de administracion de usuarios use: USERS_CONSENT_BOOTSTRAP_ESPECIALIDAD=admin

# Cookie segura solo HTTPS (produccion)
# COOKIE_SECURE=true
